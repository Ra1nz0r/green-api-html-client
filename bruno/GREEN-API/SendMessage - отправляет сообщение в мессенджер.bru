meta {
  name: SendMessage - отправляет сообщение в мессенджер
  type: http
  seq: 1
}

post {
  url: {{url}}:{{port}}/api/message
  body: json
  auth: inherit
}

body:json {
  {
    "chatId": {{chatId}},
    "message": "Привет, это тестовое сообщение"
  }
}

settings {
  encodeUrl: true
  timeout: 0
}
